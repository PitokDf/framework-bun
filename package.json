{
	"name": "buntok",
	"module": "dist/exports.js",
	"type": "module",
	"version": "0.2.2",
	"main": "dist/exports.cjs",
	"types": "dist/exports.d.ts",
	"bin": {
		"buntok": "./dist/cli/index.js"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/exports.d.ts",
				"default": "./dist/exports.js"
			},
			"require": {
				"types": "./dist/exports.d.cts",
				"default": "./dist/exports.cjs"
			}
		},
		"./middlewares/*": "./src/middlewares/*",
		"./helpers/*": "./src/helpers/*"
	},
	"files": [
		"dist",
		"devtools-ui/dist",
		"README.md"
	],
	"description": "High performance, batteries-included Bun backend framework",
	"keywords": [
		"bun",
		"framework",
		"web",
		"api",
		"typescript",
		"sse",
		"middleware"
	],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@types/bun": "latest",
		"autocannon": "^8.0.0",
		"croner": "^10.0.1",
		"elysia": "^1.4.29",
		"express": "^5.2.1",
		"fastify": "^5.10.0",
		"hono": "^4.12.29",
		"tsup": "^8.5.1"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"build": "tsup",
		"bench": "bun run bench.ts",
		"bench:prod": "bun run bench.ts --prod",
		"bench:all": "bun run benchmarks/runner.ts",
		"format": "bunx @biomejs/biome format --write .",
		"lint": "bunx @biomejs/biome lint .",
		"check": "bunx @biomejs/biome check --write .",
		"prepublishOnly": "bun run build && bun run check"
	},
	"dependencies": {
		"@asteasolutions/zod-to-openapi": "^8.5.0",
		"zod": "^4.4.3"
	}
}
